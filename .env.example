# 复制为 .env 后填写：cp .env.example .env

# 阿里云容器镜像仓库
ACR_REGISTRY=autoflux-registry.cn-hangzhou.cr.aliyuncs.com
ACR_USERNAME=labillion@1324622395035982
ACR_PASSWORD=your_password_here

# 运行镜像（默认已指向仓库）
ASR_IMAGE=autoflux-registry.cn-hangzhou.cr.aliyuncs.com/autobio/qwen3-asr-jetson:latest
ASR_PULL_POLICY=always

# 可选运行参数
# ASR_GPU_MEMORY_UTILIZATION=0.3
# ASR_GATEWAY_HOST_PORT=23311
# ASR_STARTUP_TIMEOUT_SEC=300
